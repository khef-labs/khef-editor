{
  "name": "khef-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Electron code editor (VS Code-lite) — file tree, fuzzy finder, CodeMirror editor, git. No plugins, no marketplace, no extension host.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5273 && cross-env KHEF_EDITOR_DEV=1 electron .",
    "build": "npm run build:renderer",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "npm run build && electron-builder --mac dir --publish never -c.mac.identity=null",
    "package:universal": "npm run build && electron-builder --mac dir --universal --publish never -c.mac.identity=null",
    "install:app": "bash scripts/install-app.sh",
    "install:app:universal": "bash scripts/install-app.sh --universal",
    "ke:install": "bash scripts/ke-edit.sh --install",
    "dist": "npm run build && electron-builder --mac dmg --publish never"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/codemirror-theme-monokai": "^4.25.10",
    "@uiw/codemirror-theme-solarized": "^4.25.10",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "lucide-preact": "^1.22.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "preact": "^10.25.3"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "build": {
    "appId": "ai.khef.editor",
    "productName": "Khef Editor",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "protocols": [
      {
        "name": "Khef Editor",
        "schemes": [
          "khef-editor"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": [
          "md", "markdown", "mdx", "txt", "text", "log",
          "js", "jsx", "ts", "tsx", "mjs", "cjs",
          "json", "jsonc", "css", "scss", "less", "html", "htm", "xml", "svg",
          "py", "rb", "go", "rs", "java", "c", "h", "cpp", "hpp", "cs",
          "sh", "bash", "zsh", "yml", "yaml", "toml", "ini", "conf", "env",
          "sql", "graphql", "vue", "svelte", "mmd"
        ],
        "name": "Text Document",
        "role": "Editor"
      }
    ]
  }
}
